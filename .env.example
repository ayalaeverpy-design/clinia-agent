# Autenticación:
# - CONFIG_FILE para desarrollo local con ~/.oci/config.
# - INSTANCE_PRINCIPAL para la instancia Compute en OCI.
OCI_AUTH_MODE=CONFIG_FILE

OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT

# Puede quedar vacío:
# - En CONFIG_FILE se usa el tenancy del perfil DEFAULT.
# - En INSTANCE_PRINCIPAL se usa el tenancy de la propia instancia.
OCI_COMPARTMENT_ID=

OCI_REGION=us-ashburn-1
OCI_GENERATIVE_AI_MODEL_ID=google.gemini-2.5-flash
OCI_GENERATIVE_AI_ENDPOINT=
OCI_GENERATIVE_AI_MAX_TOKENS=1000
OCI_GENERATIVE_AI_TEMPERATURE=0.15
OCI_GENERATIVE_AI_TOP_P=0.9
