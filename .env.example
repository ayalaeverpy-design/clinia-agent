# OCI SDK: el archivo real debe permanecer fuera del repositorio.
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT

# Si se deja vacío, ClinIA usa el tenancy OCID del perfil DEFAULT,
# que corresponde al compartimiento raíz seleccionado en el Playground.
OCI_COMPARTMENT_ID=

# Puede dejarse vacío para usar la región definida en ~/.oci/config.
OCI_REGION=us-ashburn-1

OCI_GENERATIVE_AI_MODEL_ID=google.gemini-2.5-flash
OCI_GENERATIVE_AI_ENDPOINT=
OCI_GENERATIVE_AI_MAX_TOKENS=1000
OCI_GENERATIVE_AI_TEMPERATURE=0.15
OCI_GENERATIVE_AI_TOP_P=0.9
