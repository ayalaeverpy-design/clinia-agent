[Unit]
Description=ClinIA Streamlit
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/clinia-agent
EnvironmentFile=/home/ubuntu/clinia-agent/.env
ExecStart=/home/ubuntu/clinia-agent/.venv/bin/python -m streamlit run app.py --server.address=0.0.0.0 --server.port=8501 --server.headless=true
Restart=always
RestartSec=5
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
